# ── Copy this to .env and fill in your values ──────────────────────────────
# Never commit .env to source control.

# PostgreSQL (your existing Postgres server)
POSTGRES_HOST=192.168.1.x          # IP or hostname of your Postgres server
POSTGRES_PORT=5432
POSTGRES_DB=market_portal
POSTGRES_USER=portal_user
POSTGRES_PASSWORD=your_secure_password_here

# n8n webhook (Webhook node URL from your n8n workflow)
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/market-report-trigger

# Portal domain (what Traefik will route)
PORTAL_DOMAIN=portal.yourdomain.com

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_hex_string

# Initial admin account (only used on very first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_immediately
